# Copy to .env.local and fill in.

# LiveKit Cloud project credentials.
# Get these from https://cloud.livekit.io → your project → Settings → Keys.
LIVEKIT_URL=wss://<your-project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Provider API keys.
ASSEMBLYAI_API_KEY=
FISH_API_KEY=

# LLM runs through LiveKit's inference gateway (the agent uses inference.LLM,
# default model google/gemini-3.5-flash). The gateway authenticates against
# LiveKit Cloud, so it needs CLOUD creds even if rooms run on a local dev server.
# It reads LIVEKIT_INFERENCE_API_KEY/SECRET first, then falls back to
# LIVEKIT_API_KEY/SECRET. Uncomment and set to a LiveKit Cloud project's
# key/secret (leave commented to use the LIVEKIT_API_KEY fallback — a present
# but empty value would override the fallback with an empty string).
# LIVEKIT_INFERENCE_API_KEY=
# LIVEKIT_INFERENCE_API_SECRET=
# Optional: override the model (provider-prefixed), e.g. openai/gpt-4.1-mini.
# LLM_MODEL=google/gemini-3.5-flash

# --- Alternative: call Google directly (LLM_BACKEND=google) ---
# Use this to run Gemma 4 (e.g. gemma-4-31b-it), which the inference gateway does
# NOT serve. Google hosts Gemma first-party on both the Gemini API and Vertex.
# LLM_BACKEND=google
# LLM_MODEL=gemma-4-31b-it
#
# Gemini API path (simplest — just an API key from https://aistudio.google.com/apikey):
# GOOGLE_API_KEY=
#
# Vertex AI path instead (GCP project + service account):
# GOOGLE_GENAI_USE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT=<your-gcp-project>
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/service-account.json

# Optional: only needed for scripts/probe_tag_fidelity.py (cross-LLM tag testing),
# not for the running agent.
# OPENAI_API_KEY=
