# Copy to .env.local and fill in.

# LiveKit Cloud project credentials.
# Get these from https://cloud.livekit.io → your project → Settings → Keys.
LIVEKIT_URL=wss://<your-project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Provider API keys.
ASSEMBLYAI_API_KEY=
OPENAI_API_KEY=
FISH_API_KEY=

# Optional: override the agent LLM (OpenAI model id; default gpt-5.1).
# OPENAI_MODEL=gpt-5.1
# Optional: override the cosmetic mood-ring classifier model (default gpt-4.1-mini).
# MOOD_MODEL=gpt-4.1-mini
